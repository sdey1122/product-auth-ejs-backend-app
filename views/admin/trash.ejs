<style>
  :root {
    --bg-main: #0f172a;
    --card-bg: #1e293b;
    --sidebar-bg: #020617;
    --border-color: #334155;
    --text-main: #e2e8f0;
    --text-muted: #94a3b8;
    --danger: #ef4444;
  }

  body {
    background: var(--bg-main);
    color: var(--text-main);
  }

  .layout {
    display: flex;
    min-height: 100vh;
  }

  /* SIDEBAR */
  .sidebar {
    width: 240px;
    background: var(--sidebar-bg);
    padding: 25px 20px;
    border-right: 1px solid var(--border-color);
  }

  .sidebar h5 {
    margin-bottom: 25px;
    font-weight: 600;
  }

  .sidebar a {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-muted);
    padding: 10px 12px;
    border-radius: 10px;
    margin-bottom: 8px;
    text-decoration: none;
    transition: 0.25s;
  }

  .sidebar a:hover {
    background: #1e293b;
    color: #fff;
    transform: translateX(4px);
  }

  .sidebar a.active {
    background: rgba(239, 68, 68, 0.1);
    color: #f87171;
  }

  /* MAIN */
  .main {
    flex: 1;
    padding: 25px;
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
  }

  /* CARD */
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    transition: 0.3s;
    overflow: hidden;
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  }

  .product-img {
    height: 170px;
    object-fit: cover;
    width: 100%;
  }

  .card-body {
    padding: 15px;
  }

  .product-name {
    font-weight: 600;
  }

  .badge-custom {
    font-size: 11px;
    padding: 5px 10px;
    border-radius: 20px;
  }

  .actions .btn {
    border-radius: 20px;
    padding: 5px 12px;
    font-size: 12px;
  }

  /* EMPTY */
  .empty-box {
    margin-top: 80px;
    text-align: center;
  }

  .empty-box h5 {
    color: var(--text-muted);
  }
</style>

<div class="layout">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h5><i class="bi bi-person-circle me-1"></i> Admin</h5>

    <a href="/admin/dashboard">
      <i class="bi bi-speedometer2"></i> Dashboard
    </a>

    <a href="/admin/products">
      <i class="bi bi-box"></i> Products
    </a>

    <a href="/admin/products/create">
      <i class="bi bi-plus-circle"></i> Create Product
    </a>

    <a href="/admin/trash" class="active">
      <i class="bi bi-trash"></i> Trash
    </a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
      <h4><i class="bi bi-trash me-2"></i> Trash Products</h4>

      <a href="/admin/products" class="btn btn-outline-light btn-sm">
        <i class="bi bi-arrow-left"></i> Back
      </a>
    </div>

    <!-- EMPTY -->
    <% if (products.length === 0) { %>
      <div class="empty-box">
        <h5>No deleted products</h5>
        <a href="/admin/products" class="btn btn-outline-light mt-3">
          Back to Products
        </a>
      </div>
    <% } %>

    <!-- GRID -->
    <div class="row g-4">

      <% products.forEach(product => { %>
        <div class="col-md-4 col-lg-3">

          <div class="card">

            <!-- IMAGE -->
            <% if (product.image?.url) { %>
              <img src="<%= product.image.url %>" class="product-img">
            <% } %>

            <div class="card-body">

              <div class="product-name"><%= product.name %></div>

              <small class="text-info"><%= product.category %></small>

              <p class="text-success mb-1">₹<%= product.price %></p>

              <!-- STATUS -->
              <span class="badge bg-secondary badge-custom me-1">
                Inactive
              </span>

              <span class="badge bg-danger badge-custom">
                Deleted
              </span>

              <!-- ACTIONS -->
              <div class="actions d-flex gap-2 mt-3">

                <!-- RESTORE -->
                <form action="/admin/products/restore/<%= product._id %>?_method=PATCH" method="POST">
                  <button class="btn btn-success btn-sm">
                    <i class="bi bi-arrow-counterclockwise"></i>
                  </button>
                </form>

                <!-- HARD DELETE -->
                <form action="/admin/products/hard-delete/<%= product._id %>?_method=DELETE" method="POST">
                  <button class="btn btn-danger btn-sm">
                    <i class="bi bi-x-circle"></i>
                  </button>
                </form>

              </div>

            </div>

          </div>

        </div>
      <% }) %>

    </div>

  </div>

</div>
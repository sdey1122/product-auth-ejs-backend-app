<style>
  :root {
    --bg-main: #0f172a;
    --card-bg: #1e293b;
    --sidebar-bg: #020617;
    --border-color: #334155;
    --text-main: #e2e8f0;
    --text-muted: #94a3b8;
    --primary: #6366f1;
  }

  body {
    background: var(--bg-main);
    color: var(--text-main);
  }

  .layout {
    display: flex;
    min-height: 100vh;
  }

  /* SIDEBAR */
  .sidebar {
    width: 240px;
    background: var(--sidebar-bg);
    padding: 25px 20px;
    border-right: 1px solid var(--border-color);
  }

  .sidebar h5 {
    margin-bottom: 25px;
    font-weight: 600;
  }

  .sidebar a {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-muted);
    padding: 10px 12px;
    border-radius: 10px;
    margin-bottom: 8px;
    text-decoration: none;
    transition: 0.25s;
  }

  .sidebar a:hover {
    background: #1e293b;
    color: #fff;
    transform: translateX(4px);
  }

  /* MAIN */
  .main {
    flex: 1;
    padding: 25px;
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    flex-wrap: wrap;
    gap: 10px;
  }

  .topbar h4 {
    margin: 0;
  }

  .btn-gradient {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    border: none;
    color: #fff;
  }

  .btn-gradient:hover {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
  }

  /* PRODUCT CARD */
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    transition: 0.3s;
    overflow: hidden;
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  }

  .product-img {
    height: 170px;
    object-fit: cover;
    width: 100%;
  }

  .card-body {
    padding: 15px;
  }

  .product-name {
    font-weight: 600;
    font-size: 15px;
  }

  .badge-status {
    font-size: 11px;
    padding: 5px 10px;
    border-radius: 20px;
  }

  .actions .btn {
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 12px;
  }

  /* EMPTY STATE */
  .empty-box {
    margin-top: 80px;
    text-align: center;
  }

  .empty-box h5 {
    color: var(--text-muted);
  }
</style>

<div class="layout">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h5><i class="bi bi-person-circle me-1"></i> Admin</h5>

    <a href="/admin/dashboard">
      <i class="bi bi-speedometer2"></i> Dashboard
    </a>

    <a href="/admin/products">
      <i class="bi bi-box"></i> Products
    </a>

    <a href="/admin/products/create">
      <i class="bi bi-plus-circle"></i> Create Product
    </a>

    <a href="/admin/trash">
      <i class="bi bi-trash"></i> Trash
    </a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
      <h4>All Products</h4>

      <a href="/admin/products/create" class="btn btn-gradient btn-sm">
        <i class="bi bi-plus-circle me-1"></i> Add Product
      </a>
    </div>

    <!-- EMPTY -->
    <% if (products.length === 0) { %>
      <div class="empty-box">
        <h5>No products found</h5>
        <a href="/admin/products/create" class="btn btn-gradient mt-3">
          Create First Product
        </a>
      </div>
    <% } %>

    <!-- GRID -->
    <div class="row g-4">

      <% products.forEach(product => { %>
        <div class="col-md-4 col-lg-3">

          <div class="card">

            <!-- IMAGE -->
            <% if (product.image?.url) { %>
              <img src="<%= product.image.url %>" class="product-img">
            <% } %>

            <div class="card-body">

              <div class="product-name"><%= product.name %></div>

              <small class="text-info"><%= product.category %></small>

              <p class="text-success mb-1">₹<%= product.price %></p>

              <span class="badge-status <%= product.status === 'active' ? 'bg-success' : 'bg-secondary' %>">
                <%= product.status %>
              </span>

              <!-- ACTIONS -->
              <div class="actions d-flex gap-1 flex-wrap mt-3">

                <a href="/admin/products/edit/<%= product._id %>" class="btn btn-primary btn-sm">
                  <i class="bi bi-pencil"></i>
                </a>

                <form action="/admin/products/status/<%= product._id %>?_method=PATCH" method="POST">
                  <button class="btn btn-info btn-sm">
                    <i class="bi bi-arrow-repeat"></i>
                  </button>
                </form>

                <form action="/admin/products/<%= product._id %>?_method=DELETE" method="POST">
                  <button class="btn btn-danger btn-sm">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>

              </div>

            </div>

          </div>

        </div>
      <% }) %>

    </div>

  </div>

</div>
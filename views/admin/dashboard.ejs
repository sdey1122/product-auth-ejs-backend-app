<style>
  :root {
    --bg-main: #0f172a;
    --card-bg: #1e293b;
    --border-color: #334155;
    --text-main: #e2e8f0;
    --text-muted: #94a3b8;
    --primary: #6366f1;
  }

  .wrapper {
    max-width: 1150px;
    margin: 50px auto;
    padding: 0 16px;
  }

  /* TOPBAR */
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 10px;
  }

  .brand {
    font-size: 20px;
    font-weight: 600;
  }

  .brand span {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .actions .btn {
    border-radius: 25px;
    padding: 6px 14px;
  }

  /* CARD */
  .card-stat {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 22px;
    height: 100%;
    transition: 0.3s;
  }

  .card-stat:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  }

  .icon-box {
    width: 50px;
    height: 50px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    margin-bottom: 12px;
    color: #fff;
  }

  .bg-blue {
    background: linear-gradient(135deg, #3b82f6, #6366f1);
  }
  .bg-green {
    background: linear-gradient(135deg, #22c55e, #4ade80);
  }
  .bg-yellow {
    background: linear-gradient(135deg, #eab308, #facc15);
  }
  .bg-red {
    background: linear-gradient(135deg, #ef4444, #f87171);
  }

  .stat-number {
    font-size: 30px;
    font-weight: 700;
  }

  .muted {
    color: var(--text-muted);
    font-size: 14px;
  }

  /* BUTTON */
  .btn-gradient {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    border: none;
    color: #fff;
  }

  .btn-gradient:hover {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
  }

  /* QUICK */
  .quick {
    margin-top: 40px;
    text-align: center;
  }

  .quick .btn {
    border-radius: 30px;
    padding: 10px 20px;
    margin: 5px;
  }

  .footer-note {
    margin-top: 50px;
    text-align: center;
    color: #64748b;
    font-size: 13px;
  }
</style>

<div class="wrapper">
  <!-- TOPBAR -->
  <div class="topbar">
    <div class="brand">
      <i class="bi bi-speedometer2 me-2"></i> Admin <span>Dashboard</span>
    </div>

    <div class="actions d-flex gap-2">
      <a href="/admin/products" class="btn btn-outline-light btn-sm">
        Products
      </a>

      <a href="/admin/products/create" class="btn btn-gradient btn-sm">
        <i class="bi bi-plus-circle me-1"></i> New
      </a>

      <a href="/auth/logout" class="btn btn-danger btn-sm">
        <i class="bi bi-box-arrow-right me-1"></i>
      </a>
    </div>
  </div>

  <!-- STATS -->
  <div class="row g-4">
    <div class="col-md-3">
      <div class="card-stat">
        <div class="icon-box bg-blue">
          <i class="bi bi-box-seam"></i>
        </div>
        <div class="stat-number"><%= totalProducts || 0 %></div>
        <div class="muted">Total Products</div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card-stat">
        <div class="icon-box bg-green">
          <i class="bi bi-check-circle"></i>
        </div>
        <div class="stat-number"><%= activeProducts || 0 %></div>
        <div class="muted">Active Products</div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card-stat">
        <div class="icon-box bg-yellow">
          <i class="bi bi-pause-circle"></i>
        </div>
        <div class="stat-number"><%= inactiveProducts || 0 %></div>
        <div class="muted">Inactive Products</div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card-stat">
        <div class="icon-box bg-red">
          <i class="bi bi-people"></i>
        </div>
        <div class="stat-number"><%= totalUsers || 0 %></div>
        <div class="muted">Total Users</div>
      </div>
    </div>
  </div>

  <!-- QUICK ACTIONS -->
  <div class="quick">
    <h5 class="mb-3">Quick Actions</h5>

    <a href="/admin/products/create" class="btn btn-gradient">
      <i class="bi bi-plus-lg me-1"></i> Add Product
    </a>

    <a href="/admin/products" class="btn btn-outline-light">
      <i class="bi bi-list-ul me-1"></i> View Products
    </a>

    <a href="/" class="btn btn-outline-info">
      <i class="bi bi-house me-1"></i> Home
    </a>
  </div>

  <div class="footer-note">
    Built with Node.js + MongoDB + EJS • Admin Panel
  </div>
</div>

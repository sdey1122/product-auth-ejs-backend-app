<style>
  :root {
    --bg-main: #0f172a;
    --card-bg: #1e293b;
    --input-bg: #334155;
    --border-color: #475569;
    --text-main: #e2e8f0;
    --text-muted: #94a3b8;
    --primary: #6366f1;
    --primary-hover: #4f46e5;
  }

  body {
    background: var(--bg-main);
    color: var(--text-main);
  }

  .container-box {
    max-width: 850px;
    margin: 60px auto;
    background: var(--card-bg);
    padding: 35px;
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  }

  .form-label {
    margin-top: 15px;
    font-weight: 500;
  }

  .form-control,
  .form-select {
    background: var(--input-bg);
    color: var(--text-main);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 10px 12px;
    transition: 0.3s;
  }

  .form-control::placeholder {
    color: var(--text-muted);
  }

  .form-control:focus,
  .form-select:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.3);
    background: var(--input-bg);
    color: #fff;
  }

  .input-group-text {
    background: var(--input-bg);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    border-radius: 10px 0 0 10px;
  }

  .btn-custom {
    border-radius: 30px;
    padding: 12px;
    font-weight: 500;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    border: none;
    transition: 0.3s;
  }

  .btn-custom:hover {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    transform: translateY(-1px);
  }

  .preview-wrapper {
    text-align: center;
    margin-top: 15px;
  }

  .preview-img {
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: 12px;
    border: 2px solid var(--border-color);
    display: none;
  }

  .form-section-title {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    margin-top: 25px;
  }
</style>

<div class="container-box">
  <h3 class="text-center mb-4">
    <i class="bi bi-box-seam me-2"></i> Create Product
  </h3>

  <form action="/admin/products" method="POST" enctype="multipart/form-data">

    <div class="form-section-title">Basic Info</div>

    <!-- NAME -->
    <label class="form-label">Product Name</label>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-tag"></i></span>
      <input type="text" name="name" class="form-control" placeholder="Enter product name" required />
    </div>

    <!-- DESCRIPTION -->
    <label class="form-label">Description</label>
    <textarea name="description" class="form-control" rows="3" placeholder="Write product description..." required></textarea>

    <!-- CATEGORY -->
    <label class="form-label">Category</label>
    <select name="category" class="form-select" required>
      <option value="">Select Category</option>
      <option value="Electronics">Electronics</option>
      <option value="Fashion">Fashion</option>
      <option value="Toys">Toys</option>
    </select>

    <div class="form-section-title">Attributes</div>

    <!-- SIZE -->
    <label class="form-label">Size</label>
    <select name="size" class="form-select" multiple required>
      <option value="S">S</option>
      <option value="M">M</option>
      <option value="L">L</option>
      <option value="XL">XL</option>
    </select>

    <!-- PRICE -->
    <label class="form-label">Price</label>
    <div class="input-group">
      <span class="input-group-text">₹</span>
      <input type="number" name="price" class="form-control" required />
    </div>

    <!-- STOCK -->
    <label class="form-label">Stock</label>
    <input type="number" name="stock" class="form-control" required />

    <div class="form-section-title">Media</div>

    <!-- IMAGE -->
    <label class="form-label">Product Image</label>
    <input type="file" name="image" class="form-control" id="imageInput" required />

    <div class="preview-wrapper">
      <img id="preview" class="preview-img" />
    </div>

    <div class="form-section-title">Status</div>

    <!-- STATUS -->
    <label class="form-label">Status</label>
    <select name="status" class="form-select">
      <option value="active">Active</option>
      <option value="inactive">Inactive</option>
    </select>

    <!-- BUTTON -->
    <button class="btn btn-custom w-100 mt-4">
      <i class="bi bi-check-circle me-2"></i> Create Product
    </button>

  </form>
</div>

<script>
  const imageInput = document.getElementById("imageInput");
  const preview = document.getElementById("preview");

  imageInput.addEventListener("change", function () {
    const file = this.files[0];

    if (file) {
      preview.src = URL.createObjectURL(file);
      preview.style.display = "block";
    }
  });
</script>